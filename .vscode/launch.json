{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MCP Server",
      "type": "debugpy",
      "request": "launch",
      "module": "mcp_server.src.server",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Orchestrator Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "a2a_agents.orchestrator.agent",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Risk Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "a2a_agents.risk_agent.agent",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Coverage Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "a2a_agents.coverage_agent.agent",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Education Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "a2a_agents.education_agent.agent",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Postpartum Watch Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "a2a_agents.postpartum_watch.agent",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Pytest current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full stack (MCP + 5 agents)",
      "configurations": [
        "MCP Server",
        "Orchestrator Agent",
        "Risk Agent",
        "Coverage Agent",
        "Education Agent",
        "Postpartum Watch Agent"
      ],
      "stopAll": true
    }
  ]
}
