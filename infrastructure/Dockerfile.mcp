# MaternaSquad MCP server image.
# Build:   docker build -f infrastructure/Dockerfile.mcp -t maternasquad-mcp .
# Run:     docker run -p 8080:8080 --env-file .env maternasquad-mcp

FROM python:3.11-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install -r requirements.txt

COPY pyproject.toml ./
COPY mcp_server ./mcp_server
COPY a2a_agents ./a2a_agents

RUN useradd --create-home --uid 1001 maternasquad \
    && mkdir -p /app/audit \
    && chown -R maternasquad:maternasquad /app
USER maternasquad

ENV MCP_SERVER_HOST=0.0.0.0 \
    MCP_SERVER_PORT=8080

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -fsS "http://localhost:${MCP_SERVER_PORT}/healthcheck" || exit 1

CMD ["python", "-m", "mcp_server.src.server"]
