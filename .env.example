# Copy to .env and fill in real values. Do not commit .env.

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Google Cloud (still needed for Cloud Run deploy target)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# FHIR server (local dev)
FHIR_BASE_URL=http://localhost:8090/fhir
FHIR_ACCESS_TOKEN=

# MCP server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# A2A agents
ORCHESTRATOR_PORT=8001
RISK_AGENT_PORT=8002
COVERAGE_AGENT_PORT=8003
EDUCATION_AGENT_PORT=8004
POSTPARTUM_WATCH_PORT=8005

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Audit trail (local file path for hackathon, would be GCS/BigQuery in prod)
AUDIT_LOG_PATH=./audit/maternasquad.log

# Prompt Opinion (fill in after registering)
PROMPT_OPINION_API_KEY=
PROMPT_OPINION_WORKSPACE_ID=
